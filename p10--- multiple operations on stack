import java.util.Scanner;
class StackData {
static final int MAXSIZE = 25;
static int[] arr = new int[MAXSIZE];
static int top = -1;
}
class StackOperations {
public static void create() {
StackData.top = -1;
System.out.println("New stack created.");
}
public static void push(Scanner sc){
System.out.print("How many elements to push? ");
int n = sc.nextInt();
for(int i=0; i<n; i++) {
if (StackData.top == StackData.MAXSIZE - 1) {
System.out.println("Overflow! Stack is full.");
break;
}
System.out.print("Enter value " + (i+1) + ": ");
StackData.top++;
StackData.arr[StackData.top] = sc.nextInt();
}
}
public static void pop(Scanner sc) {
if (StackData.top == -1) {
System.out.println("Underflow! Stack is empty.");
return;
}
System.out.print("How many elements to pop? ");
int n = sc.nextInt();
for(int i=0; i<n; i++) {
if (StackData.top == -1) {
System.out.println("Stack became empty.");
break;
}
System.out.println("Popped: " + StackData.arr[StackData.top]);
StackData.top--;
}
}
public static void traverse() {
if (StackData.top == -1) {
System.out.println("Stack is empty.");
} else {
System.out.println("---Stack is---");
for (int i = StackData.top; i >= 0; i--) {
System.out.println(StackData.arr[i]);
}
}
}
}
public class p10{
public static void main(String[] args) {
Scanner sc = new Scanner(System.in);
int choice = 0;
while (choice != 5){
System.out.println("1.Create 2.Push 3.Pop 4.Traverse 5.Exit");
System.out.print("Choice: ");
choice = sc.nextInt();
switch (choice) {
case 1:
StackOperations.create(); 
break;
case 2:
StackOperations.push(sc); 
break;
case 3:
StackOperations.pop(sc); 
break;
case 4:
StackOperations.traverse(); 
break;
case 5: 
System.out.println("Exiting..."); 
break;
default:
System.out.println("Invalid!");
}
}
}
}
