class QueueLogic {
    int[] queue;
    int front, rear, capacity;

    // Create: Initialize the queue
    QueueLogic(int size) {
        capacity = size;
        queue = new int[capacity];
        front = -1;
        rear = -1;
    }

    // Insertion: Add an element
    void enqueue(int value) {
        if (rear == capacity - 1) {
            System.out.println("❌ Overflow: Cannot add " + value);
            return;
        }
        if (front == -1) front = 0;
        queue[++rear] = value;
        System.out.println("Added: " + value);
    }

    // Deletion: Remove an element
    void dequeue() {
        if (front == -1 || front > rear) {
            System.out.println("⚠️ Underflow: Queue is empty!");
            return;
        }
        System.out.println("🗑️ Removed: " + queue[front]);
        front++;
        
        // Reset pointers if queue becomes empty to save space
        if (front > rear) {
            front = rear = -1;
        }
    }

    // Traverse: Show all elements
    void display() {
        if (front == -1 || front > rear) {
            System.out.println("📂 Queue is empty.");
            return;
        }
        System.out.print("Queue Content: ");
        for (int i = front; i <= rear; i++) {
            System.out.print(queue[i] + " ");
        }
        System.out.println();
    }
}
